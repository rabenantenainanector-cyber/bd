rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Reusable Primitives and Global Helpers
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 3. Entity Validation Helpers (The Anti-Update-Gap blueprints)
    function isValidProfile(data) {
      return data.keys().hasAll(['email', 'savingsGoal', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.email is string && data.email.size() <= 256
        && data.savingsGoal is number && data.savingsGoal >= 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['description', 'amount', 'type', 'category', 'date', 'createdAt', 'updatedAt'])
        && data.keys().size() == 7
        && data.description is string && data.description.size() <= 100
        && data.amount is number && data.amount >= 0
        && (data.type == 'charge' || data.type == 'revenue')
        && data.category is string && data.category.size() <= 50
        && data.date is string && data.date.size() <= 10
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['category', 'monthlyLimit', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.category is string && data.category.size() <= 50
        && data.monthlyLimit is number && data.monthlyLimit >= 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['title', 'message', 'category', 'type', 'createdAt', 'read'])
        && data.keys().size() == 6
        && data.title is string && data.title.size() <= 100
        && data.message is string && data.message.size() <= 500
        && data.category is string && data.category.size() <= 50
        && (data.type == 'warning' || data.type == 'info')
        && data.createdAt is timestamp
        && data.read is bool;
    }

    // 4. Match Rules for collections
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidProfile(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().updatedAt == request.time
        && (incoming().email == request.auth.token.email || request.auth.token.email == null); // Handle potential email auth forms
      
      allow update: if isOwner(userId) 
        && isValidProfile(incoming()) 
        && incoming().email == existing().email 
        && incoming().createdAt == existing().createdAt 
        && incoming().updatedAt == request.time;
      
      allow delete: if isOwner(userId);

      // Sub-collection: Transactions (expenses & incomes)
      match /transactions/{transactionId} {
        allow read, list: if isOwner(userId);
        
        allow create: if isOwner(userId)
          && isValidId(transactionId)
          && isValidTransaction(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
          
        allow update: if isOwner(userId)
          && isValidId(transactionId)
          && isValidTransaction(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time;
          
        allow delete: if isOwner(userId) && isValidId(transactionId);
      }

      // Sub-collection: Category Budgets (monthly spending goals)
      match /budgets/{budgetId} {
        allow read, list: if isOwner(userId);
        
        allow create: if isOwner(userId)
          && isValidId(budgetId)
          && isValidBudget(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
          
        allow update: if isOwner(userId)
          && isValidId(budgetId)
          && isValidBudget(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time;
          
        allow delete: if isOwner(userId) && isValidId(budgetId);
      }

      // Sub-collection: Savings and Overbenefit Alerts
      match /alerts/{alertId} {
        allow read, list: if isOwner(userId);
        
        allow create: if isOwner(userId)
          && isValidId(alertId)
          && isValidAlert(incoming())
          && incoming().createdAt == request.time;
          
        allow update: if isOwner(userId)
          && isValidId(alertId)
          && isValidAlert(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
          
        allow delete: if isOwner(userId) && isValidId(alertId);
      }
    }
  }
}
